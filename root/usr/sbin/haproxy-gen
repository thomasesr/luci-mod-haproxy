#!/bin/sh
. /lib/functions.sh

# Matches HAPROXY_CONFIG in the OpenWrt haproxy init script (/etc/haproxy.cfg).
CFG="/etc/haproxy.cfg"

# Build and validate the config in /tmp (RAM tmpfs) so flash is only written
# once the config is known-good. STAGE never crosses into /etc.
STAGE="/tmp/haproxy-gen.$$.cfg"
RULES_TMP="/tmp/haproxy-rules.$$"

# Install temp lives on the SAME filesystem as CFG so the final swap is an
# atomic rename (mv across filesystems would be a non-atomic copy+unlink).
INSTALL_TMP="${CFG}.tmp"

cleanup() { rm -f "$STAGE" "$RULES_TMP" "$INSTALL_TMP"; }
trap cleanup EXIT

die() { echo "haproxy-gen: error: $*" >&2; exit 1; }

config_load haproxy

write_global() {
    local maxconn log stats_socket
    config_get maxconn      globals maxconn       '4096'
    config_get log          globals log           'stdout local0'
    config_get stats_socket globals stats_socket  '/var/run/haproxy/haproxy.sock'

    cat >> "$STAGE" <<EOF
global
    maxconn ${maxconn}
    log ${log}
    stats socket ${stats_socket} mode 660 level admin expose-fd listeners
    stats timeout 30s

defaults
    mode tcp
    log global
    option tcplog
    timeout connect 5s
    timeout client  50s
    timeout server  50s

EOF
}

# Sanitizes an arbitrary string into a haproxy-safe identifier.
sanitize() { printf '%s' "$1" | tr -c 'A-Za-z0-9' '_'; }

# A rule binds one server to a list of subdomains. The server's port list
# (from the server section) supplies BOTH the listen port and the backend port
# — one frontend/backend pair per port. resolve_rule emits one line per
# (subdomain x port) combination:
#
#   port fqdn server_host backend_id
#
# where backend_id = "<server_id>_<port>" so all subdomains sharing a server
# and port fan into a single backend. SRV_* / RULE_* globals carry state into
# the config_list_foreach callbacks (functions.sh runs them in-process).
resolve_rule() {
    local sid="$1"
    local server_id

    config_get server_id "$sid" server
    [ -n "$server_id" ] || {
        echo "haproxy-gen: skipping rule '${sid}': no server" >&2
        return
    }

    config_get RULE_HOST "$server_id" host
    RULE_SERVER="$server_id"
    [ -n "$RULE_HOST" ] || {
        echo "haproxy-gen: skipping rule '${sid}': server '${server_id}' has no host" >&2
        return
    }

    SRV_PORTS=""
    config_list_foreach "$server_id" ports _collect_port
    [ -n "$SRV_PORTS" ] || {
        echo "haproxy-gen: skipping rule '${sid}': server '${server_id}' has no ports" >&2
        return
    }

    RULE_HAS_SUB=0
    config_list_foreach "$sid" subdomain _emit_subdomain
    [ "$RULE_HAS_SUB" = 1 ] || \
        echo "haproxy-gen: skipping rule '${sid}': no resolvable subdomains" >&2
}

_collect_port() { SRV_PORTS="${SRV_PORTS} $1"; }

_emit_subdomain() {
    local sub_id="$1"
    local sub_name domain_id domain_name fqdn port

    config_get sub_name    "$sub_id"    name
    config_get domain_id   "$sub_id"    domain
    config_get domain_name "$domain_id" name

    [ -n "$sub_name" ] && [ -n "$domain_name" ] || {
        echo "haproxy-gen: rule references unresolvable subdomain '${sub_id}'" >&2
        return
    }

    fqdn="${sub_name}.${domain_name}"
    RULE_HAS_SUB=1
    for port in $SRV_PORTS; do
        printf '%s %s %s %s_%s\n' "$port" "$fqdn" "$RULE_HOST" "$RULE_SERVER" "$port"
    done
}

# One frontend per listen port: an SNI ACL per distinct FQDN, then a
# use_backend per FQDN routing to that FQDN's backend on this port.
write_frontend() {
    local port="$1"
    local inspect_delay
    config_get inspect_delay globals inspect_delay '5s'

    {
        printf 'frontend ft_%s\n'                                     "$port"
        printf '    bind *:%s\n'                                       "$port"
        printf '    mode tcp\n'
        printf '    tcp-request inspect-delay %s\n'                   "$inspect_delay"
        printf '    tcp-request content accept if { req_ssl_hello_type 1 }\n'
        printf '\n'

        # acl per distinct FQDN on this port
        grep "^${port} " "$RULES_TMP" | awk '{print $2}' | sort -u | while read -r fqdn; do
            printf '    acl sni_%s req_ssl_sni -i %s\n' "$(sanitize "$fqdn")" "$fqdn"
        done

        # use_backend per distinct FQDN (first backend wins on collision)
        grep "^${port} " "$RULES_TMP" | awk '!seen[$2]++ { print $2, $4 }' | while read -r fqdn bkid; do
            printf '    use_backend bk_%s if sni_%s\n' "$bkid" "$(sanitize "$fqdn")"
        done

        printf '\n'
    } >> "$STAGE"
}

# One backend per distinct (server, port) pair → host:port.
write_backends() {
    awk '{print $4, $3, $1}' "$RULES_TMP" | sort -u | while read -r bkid host port; do
        {
            printf 'backend bk_%s\n'        "$bkid"
            printf '    mode tcp\n'
            printf '    server s1 %s:%s\n'  "$host" "$port"
            printf '\n'
        } >> "$STAGE"
    done
}

# Extracts the unique TCP listen ports from a config file.
listen_ports() {
    awk '/^[[:space:]]*bind /{ n=split($0,a,":"); p=a[n]; gsub(/[^0-9]/,"",p); if (p!="") print p }' \
        "$1" | sort -un
}

# Checks each listen port for a conflicting listener owned by a process other
# than haproxy. Prints a human-readable conflict list and returns 1 on
# conflict; returns 0 when all ports are free (or held only by haproxy).
# If program ownership can't be determined (no -p support), it does not abort.
check_ports() {
    local ports="$1"
    local netstat_out conflicts="" p owners

    command -v netstat >/dev/null 2>&1 || return 0
    netstat_out="$(netstat -lntp 2>/dev/null)"

    for p in $ports; do
        # Match listeners whose local address ends in :<port>, excluding
        # haproxy's own sockets and entries with no resolvable program name.
        owners="$(printf '%s\n' "$netstat_out" | awk -v re="[:.]${p}\$" '
            $1 ~ /^tcp/ && $4 ~ re { n = split($NF, a, "/"); print (n > 1 ? a[2] : "") }' \
            | grep -v '^haproxy$' | grep -v '^$' | grep -v '^-$' | sort -u | tr '\n' ',')"
        owners="${owners%,}"
        [ -n "$owners" ] && conflicts="${conflicts}${conflicts:+; }port ${p} already in use by ${owners}"
    done

    [ -n "$conflicts" ] && { printf '%s\n' "$conflicts"; return 1; }
    return 0
}

main() {
    mkdir -p "$(dirname "$CFG")"
    : > "$STAGE" || die "cannot write staging file ${STAGE}"

    write_global

    config_foreach resolve_rule rule > "$RULES_TMP"

    if [ -s "$RULES_TMP" ]; then
        local dupes
        dupes=$(awk '{print $1 " " $2}' "$RULES_TMP" | sort | uniq -d)
        [ -n "$dupes" ] && echo "haproxy-gen: warning: duplicate port+SNI combos will shadow each other:" >&2 \
                        && echo "$dupes" >&2

        local ports
        ports=$(awk '{print $1}' "$RULES_TMP" | sort -un)

        for port in $ports; do
            write_frontend "$port"
        done

        write_backends
    else
        echo "haproxy-gen: warning: no usable rules — generated config has no frontends" >&2
    fi

    # 1. Syntax + semantic validation. Does NOT bind ports, so it is safe to
    #    run against the staged temp file while the live config keeps serving.
    local check_out
    check_out="$(haproxy -c -f "$STAGE" 2>&1)" \
        || die "config validation failed, live config untouched:
${check_out}"

    # 2. Port availability. Refuse to reload if a non-haproxy process already
    #    holds one of the listen ports — otherwise haproxy fails to bind on
    #    reload and the new rule silently never takes effect.
    local bind_ports conflict
    bind_ports="$(listen_ports "$STAGE")"
    if [ -n "$bind_ports" ]; then
        conflict="$(check_ports "$bind_ports")" \
            || die "refusing to reload — ${conflict}"
    fi

    # 3. Install. STAGE is on tmpfs and CFG on flash (different filesystems),
    #    so copy STAGE onto a temp NEXT TO CFG, then rename — the rename is
    #    same-filesystem and therefore atomic. A direct mv from /tmp would be
    #    a non-atomic cross-filesystem copy+unlink.
    cp "$STAGE" "$INSTALL_TMP" || die "failed to stage config at ${INSTALL_TMP}"
    [ -s "$INSTALL_TMP" ] || die "staged config ${INSTALL_TMP} is empty"

    trap - EXIT
    rm -f "$STAGE" "$RULES_TMP"
    mv "$INSTALL_TMP" "$CFG" || die "failed to install ${CFG}"

    service haproxy reload
}

main "$@"
