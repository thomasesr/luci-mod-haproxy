{
	"luci-mod-haproxy": {
		"description": "HAProxy SNI Passthrough Manager",
		"read": {
			"uci": [ "haproxy" ],
			"file": {
				"/etc/haproxy.cfg": [ "read" ],
				"/usr/sbin/haproxy-status": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "haproxy" ],
			"file": {
				"/usr/sbin/haproxy-gen": [ "exec" ],
				"/usr/sbin/haproxy-ctl": [ "exec" ]
			}
		}
	}
}
